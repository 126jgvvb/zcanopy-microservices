{
  "info": {
    "name": "ZCanopy API Gateway",
    "description": "Postman collection for ZCanopy microservices API Gateway running on port 4000",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "baseUrl": "http://localhost:4000/api",
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000/api"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "sessionToken",
      "value": ""
    },
    {
      "key": "customerSessionToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Admin Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@zcanopy.com\",\n  \"password\": \"admin123\",\n  \"type\": \"admin\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Broker Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/broker/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"brokerCode\": \"BROKER123\",\n  \"password\": \"password123\",\n  \"deviceId\": \"device-001\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{accessToken}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        }
      ]
    },
    {
      "name": "Customer",
      "item": [
        {
          "name": "Get Customer Properties",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/customer/properties",
            "params": [
              { "key": "sessionToken", "value": "{{customerSessionToken}}" },
              { "key": "page", "value": "1" },
              { "key": "limit", "value": "10" },
              { "key": "lat", "value": "0.3476" },
              { "key": "lng", "value": "32.5825" },
              { "key": "radiusKm", "value": "10" }
            ]
          }
        },
        {
          "name": "Search Properties by Broker Title",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/customer/search",
            "params": [
              { "key": "q", "value": "broker name" },
              { "key": "sessionToken", "value": "{{customerSessionToken}}" },
              { "key": "page", "value": "1" },
              { "key": "limit", "value": "10" }
            ]
          }
        },
        {
          "name": "Initiate Property Access Payment",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/customer/properties/access-payment",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionToken\": \"{{customerSessionToken}}\",\n  \"brokerCode\": \"BROKER123\",\n  \"propertyId\": \"prop-123\",\n  \"amount\": 5000,\n  \"customerEmail\": \"customer@example.com\",\n  \"customerPhone\": \"0700000000\",\n  \"customerName\": \"John Doe\",\n  \"careerExamples\": \"Real estate investor\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Get Broker Properties for Customer",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/customer/broker-properties",
            "params": [
              { "key": "sessionToken", "value": "{{customerSessionToken}}" },
              { "key": "brokerCode", "value": "BROKER123" },
              { "key": "page", "value": "1" },
              { "key": "limit", "value": "10" }
            ]
          }
        },
        {
          "name": "Create Customer Booking",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/customer/bookings",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionToken\": \"{{customerSessionToken}}\",\n  \"propertyId\": \"prop-123\",\n  \"customerName\": \"John Doe\",\n  \"customerPhone\": \"0700000000\",\n  \"customerEmail\": \"john@example.com\",\n  \"date\": \"2024-12-01\",\n  \"amount\": 10000,\n  \"reason\": \"Property viewing\",\n  \"status\": \"confirmed\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Get Property Details for Customer",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/customer/properties/prop-123/details",
            "params": [
              { "key": "sessionToken", "value": "{{customerSessionToken}}" }
            ]
          }
        },
        {
          "name": "Get Customer Bookings",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/customer/bookings",
            "params": [
              { "key": "sessionToken", "value": "{{customerSessionToken}}" },
              { "key": "page", "value": "1" },
              { "key": "limit", "value": "10" }
            ]
          }
        },
        {
          "name": "Get Booking by Code",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/customer/bookings/code/TXN123456",
            "params": []
